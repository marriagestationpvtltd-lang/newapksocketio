<?xml version="1.0" encoding="utf-8"?>
<!-- White background with centered app logo shown before Flutter draws its first frame.
     Using a fixed white color (not ?android:colorBackground) prevents the black
     screen that appears on dark-mode devices during engine startup. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/launch_background" />

    <!-- Centered app logo for visual continuity with the Flutter splash screen -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_launcher" />
    </item>
</layer-list>
