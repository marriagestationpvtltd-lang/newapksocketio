# ────────────────────────────────────────────────────────────────────────────
# Marriage Station – Socket.IO Server  (.env.example)
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env          (Linux / macOS / Git-Bash)
#   copy .env.example .env        (Windows CMD)
#
# The .env file is gitignored — never commit real credentials.
# ────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Socket.IO / Express server will listen on.
PORT=3001

# Absolute or relative path where uploaded chat images & voice messages are stored.
UPLOAD_DIR=./uploads

# Comma-separated list of allowed CORS origins.
# Use * to allow all origins (fine for local dev, restrict in production).
# For production, add your domain URLs:
#   ALLOWED_ORIGINS=https://react.marriagestation.com.np,https://adminnew.marriagestation.com.np
ALLOWED_ORIGINS=https://react.marriagestation.com.np,https://adminnew.marriagestation.com.np

# ── MySQL Database (main) ────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=marriagestation_mschat
DB_USER=marriagestation_mschat
DB_PASS=

# ── MySQL Database (admin-chat) ──────────────────────────────────────────────
# Set these only if the admin-chat database lives on a different MySQL instance.
# Leave them blank to reuse the main DB connection above.
ADMINCHAT_DB_HOST=127.0.0.1
ADMINCHAT_DB_NAME=marriagestation_mschat
ADMINCHAT_DB_USER=marriagestation_mschat
ADMINCHAT_DB_PASS=

# ── Agora (WebRTC token generation — server-side only) ───────────────────────
# Required only if the server generates RTC tokens itself.
# Leave blank to disable the /agora-token endpoint.
AGORA_APP_ID=
AGORA_APP_CERT=
