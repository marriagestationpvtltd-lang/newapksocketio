# ────────────────────────────────────────────────────────────────────────────
# Marriage Station – PHP Backend  (.env.example)
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is loaded automatically by config/db.php.
# The .env file is gitignored — never commit real credentials.
# ────────────────────────────────────────────────────────────────────────────

# ── Main "ms" Database ───────────────────────────────────────────────────────
# LOCAL (XAMPP / WAMP / MAMP): keep DB_USER=root, DB_PASS empty
# SHARED HOSTING: use the credentials from your hosting control panel
DB_HOST=localhost
DB_NAME=ms
DB_USER=root
DB_PASS=

# ── Admin-chat Database ──────────────────────────────────────────────────────
# If the adminchat DB is on the same server/user as the main DB,
# you can leave these blank and the values from DB_HOST / DB_USER / DB_PASS
# will be reused automatically.
ADMINCHAT_DB_HOST=localhost
ADMINCHAT_DB_NAME=adminchat
ADMINCHAT_DB_USER=root
ADMINCHAT_DB_PASS=

# ── Public URL ────────────────────────────────────────────────────────────────
# LOCAL development: use your machine's LAN IP (find it with `ip addr` / ipconfig).
#   Example: http://192.168.1.10
#   The full local API path is: http://<LAN_IP>/www/wwwroot/digitallami.com
#
# SHARED HOSTING: use the actual domain, no sub-path needed.
#   Example: https://digitallami.com
#
# This value is also used as the base URL for uploaded media links returned
# to the Flutter app, so it MUST be reachable from the mobile device.
APP_PUBLIC_BASE_URL=http://localhost

# ── Flutter app URL configuration ────────────────────────────────────────────
# Update kApiBaseUrl in msfinal/lib/config/app_endpoints.dart to match:
#   LOCAL:          http://<LAN_IP>/www/wwwroot/digitallami.com
#   SHARED HOSTING: https://digitallami.com
#
# Pass at Flutter build time to avoid editing the source file:
#   flutter run --dart-define=API_BASE_URL=http://192.168.1.10/www/wwwroot/digitallami.com

# ── Agora (Voice / Video Calls) ──────────────────────────────────────────────
# Obtain these from https://console.agora.io → your project → App ID & Certificate.
# Leave blank to disable server-side Agora token generation.
AGORA_APP_ID=
AGORA_APP_CERT=

# ── Firebase Configuration ───────────────────────────────────────────────────
# Firebase Realtime Database URL for server-side operations
# Example: https://your-project-default-rtdb.firebaseio.com/
FIREBASE_DATABASE_URL=https://digitallamicomnp-default-rtdb.firebaseio.com/

# ── Email Configuration ──────────────────────────────────────────────────────
# No-reply email address for system notifications (password reset, OTP, etc.)
NO_REPLY_EMAIL=no-reply@digitallami.com

# ── Khalti Payment Gateway ───────────────────────────────────────────────────
# Khalti secret key (get from https://khalti.com/merchant dashboard)
KHALTI_SECRET_KEY=
# Return URL after payment completion (must contain "success.php" in path)
KHALTI_RETURN_URL=https://react.marriagestation.com.np/khalti_success.php
# Your website URL for Khalti
KHALTI_WEBSITE_URL=https://react.marriagestation.com.np

# ── One-time setup / migration token ─────────────────────────────────────────
# Set a strong random value here and pass it as ?token=<value> when running
# api9/run_migration.php for the first time.  Remove run_migration.php from
# the server after the migration has been applied.
SETUP_TOKEN=
