# CORS headers are set exclusively by shared/cors.php (included via config/db.php).
# Using only PHP header() calls avoids the duplicate "*, *" value that results when
# both mod_headers and PHP emit the same header concurrently.

# Deny direct HTTP access to environment and configuration files.
<FilesMatch "^(\.env|\.env\.example)$">
    Order allow,deny
    Deny from all
</FilesMatch>
